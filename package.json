{
  "name": "@0x-jerry/unplugin-env",
  "type": "module",
  "version": "0.1.3",
  "packageManager": "pnpm@8.15.8",
  "description": "Auto generate typedef for env variables.",
  "license": "MIT",
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "transform"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./types": "./dist/types.mjs",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "npm -C playground run dev",
    "prepublishOnly": "npm run build",
    "release": "bumpp",
    "test": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x-jerry/unplugin-env.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/0x-jerry/unplugin-env/issues"
  },
  "homepage": "https://github.com/0x-jerry/unplugin-env#readme"
}
